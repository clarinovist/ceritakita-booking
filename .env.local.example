# ========================================
# CeritaKita Booking App - Environment Variables
# ========================================
# Copy this file to .env.local and update the values

# Admin Credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_generated_secret_here

# ========================================
# Public Site URL (SEO / Metadata)
# ========================================
# Used for generating absolute canonical/OpenGraph URLs.
# Set this to your production domain.
NEXT_PUBLIC_SITE_URL=https://ceritakitastudio.site

# ========================================
# Backblaze B2 Storage Configuration
# ========================================
B2_APPLICATION_KEY_ID=your_b2_key_id_here
B2_APPLICATION_KEY=your_b2_application_key_here
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
B2_BUCKET_NAME=your_bucket_name_here

# ========================================
# Meta Marketing API Configuration
# ========================================
# Required for fetching Ads Insights data
# Get these from Meta Business Manager:
# 1. Go to https://business.facebook.com/
# 2. Go to Business Settings > Users > System Users
# 3. Create a System User and generate Access Token
# 4. Go to Ads Manager > Get Ad Account ID (e.g., act_123456789)

META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id_here

# Optional: Meta API Version (defaults to v19.0 if not specified)
META_API_VERSION=v19.0

# ========================================
# Email & Reports Configuration (Resend)
# ========================================
RESEND_API_KEY=your_resend_api_key_here
REPORT_EMAIL_TO=your_reporting_email@example.com
REPORT_CRON_SECRET=your_random_secret_for_cron_trigger

# ========================================
# WhatsApp Provider Configuration
# ========================================
# Provider: 'watzap' (recommended) or 'wati' (legacy)
WHATSAPP_PROVIDER=watzap

# WhatsApp redirect number (used in /api/wa/[source] wa.me redirects)
# Format: 628xxxxxxxxxx (international, no +)
WA_NUMBER=6285190832058

# Watzap Official API
WATZAP_API_KEY=your_watzap_api_key_here
WATZAP_BASE_URL=https://api.watzap.id/v1
WATZAP_WABA_ID=your_waba_id_here

# WATI (legacy fallback, optional)
WATI_API_ENDPOINT=your_wati_endpoint_here
WATI_API_TOKEN=your_wati_api_token_here
WATI_WEBHOOK_SECRET=your_wati_webhook_secret_here

# ========================================
# AI CS Brain Configuration
# ========================================
AI_CS_ENABLED=false
# Supported values: openai, gemini, deepseek, openrouter, custom
AI_CS_PROVIDER=openai
# Example values: gpt-4o-mini, gemini-1.5-flash, deepseek-chat, anthropic/claude-3.5-sonnet
AI_CS_MODEL=gpt-4o-mini

# Optional: Custom base URL (used only when AI_CS_PROVIDER=custom)
# DeepSeek/OpenRouter/OpenAI/Gemini providers use their built-in endpoints automatically.
# Custom example: https://your-openai-compatible-endpoint/v1
AI_CS_BASE_URL=
# Required for provider=custom: comma-separated domain allowlist (security)
# Example: api.mycompany.ai,openai-proxy.mycompany.com
AI_CS_CUSTOM_BASE_URL_ALLOWLIST=

# AI Modes
AI_CS_INSIGHT_ENABLED=true
AI_CS_DRAFT_ENABLED=true
AI_CS_AUTO_SEND_ENABLED=false

# Safety & Cost Control
AI_CS_MAX_CONTEXT_MESSAGES=30
AI_CS_TEMPERATURE=0.2
AI_CS_CONFIDENCE_AUTO_SEND_THRESHOLD=0.85
AI_CS_ALLOWED_AUTO_INTENTS=schedule_check,booking_request,testimonial,unknown

# Provider Secrets
# OPENAI_API_KEY works for: OpenAI, DeepSeek, OpenRouter, and custom OpenAI-compatible providers
OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY only for Google Gemini provider
GEMINI_API_KEY=your_gemini_api_key_here
